    "clsx": "^2.1.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-sitemap": "^4.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-pretty-code": "^0.14.3",
